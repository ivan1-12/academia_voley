# Copia este archivo a .env y ajusta valores locales
SECRET_KEY=genera-una-clave-segura-aqui
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=academia_voley
UPLOAD_FOLDER=static/uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,svg
LOGO_EXTENSIONS=png,jpg,jpeg,webp,svg
MAX_CONTENT_LENGTH=16777216
BABEL_SUPPORTED_LOCALES=es,en,pt,fr

# Servidor Flask (producción: FLASK_DEBUG=0)
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
LAST_ACTIVITY_INTERVAL=120

# Credenciales del súper usuario para scripts de migración
ADMIN_EMAIL=admin@academiavoley.net
ADMIN_PASSWORD=cambia-esta-contraseña

# Variables para scripts/manage_db.py (crear entrenador)
TRAINER_NOMBRE=Carlos
TRAINER_APELLIDO=Mendoza
TRAINER_EMAIL=entrenador@local
TRAINER_PASSWORD=changeme
